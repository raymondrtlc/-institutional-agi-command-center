KAFKA_TOPIC_PRICE=market.price.es
KAFKA_TOPIC_OPTIONS=market.options.es
KAFKA_TOPIC_NEWS=market.news.financial
KAFKA_TOPIC_SIGNALS=market.signals.trade
KAFKA_GROUP_ID=agi-command-center

# RabbitMQ - Alternative message queue
