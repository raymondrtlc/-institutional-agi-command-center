DATADOG_APP_KEY=your_datadog_app_key

################################################################################
# 16. DATA QUALITY & SELF-CORRECTION FRAMEWORK
################################################################################

# Data Validation
VALIDATE_DATA_QUALITY=True
DATA_QUALITY_MIN_ACCURACY=0.95
AUTO_REPAIR_GAPS=True
GAP_DETECTION_LOOKBACK_BARS=50

# Model Validation & Drift Detection
CROSS_VALIDATE_PREDICTIONS=True
ENSEMBLE_AGREEMENT_THRESHOLD=0.65
AUTO_RETRAIN_ON_DRIFT=True
DRIFT_DETECTION_WINDOW_DAYS=7

# Trade Signal Validation
REQUIRE_MULTI_TIMEFRAME_CONFIRMATION=True
MULTI_TF_AGREEMENT_THRESHOLD=0.7
MAX_SIGNAL_AGE_SECONDS=300
VALIDATE_AGAINST_GAMMA=True
VALIDATE_AGAINST_OPTIONS_FLOW=True

# News/Event Validation
CROSS_REFERENCE_NEWS_SOURCES=True
MINIMUM_NEWS_SOURCES=3
SENTIMENT_CONSISTENCY_THRESHOLD=0.7

################################################################################
# 17. ANALYSIS CONFIGURATION - MULTI-TIMEFRAME & PATTERNS
################################################################################

# Timeframes to analyze (Monthly → 5min as specified)
TIMEFRAMES_ENABLED=monthly,weekly,daily,4h,1h,30min,15min,5min

# Technical Analysis Modules
ENABLE_TECHNICAL_ANALYSIS=True
ENABLE_CANDLESTICK_PATTERNS=True  # Reversal patterns
ENABLE_VOLUME_PRICE_ANALYSIS=True  # 量价
ENABLE_CHAN_THEORY=True  # 缠论 (Elliott Wave + Chinese charting)
ENABLE_WYCKOFF_ANALYSIS=True  # Wyckoff accumulation/distribution

# Derivatives Analytics
ENABLE_OPTIONS_FLOW=True
ENABLE_GAMMA_EXPOSURE=True  # ✅ Gamma exposure tracking
ENABLE_GAMMA_FLIP=True  # ✅ Gamma flip alerts
ENABLE_MAX_PAIN=True  # ✅ Max pain calculation
ENABLE_DEALER_POSITIONING=True  # ✅ Large dealer flow
ENABLE_DARK_POOL_ANALYSIS=True  # ✅ Dark pool monitoring
ENABLE_ZERO_DTE=True  # ✅ 0DTE positioning
ENABLE_SHORT_SQUEEZE=True  # ✅ Short squeeze probability

# Market Sentiment & Structure
ENABLE_CNN_FEAR_GREED=True  # ✅ CNN Fear & Greed index
ENABLE_MAG7_ANALYSIS=True  # ✅ MAG7 (MSFT, AAPL, GOOGL, AMZN, NVDA, META, TSLA) leadership
ENABLE_MARKET_BREADTH=True  # ✅ Breadth indicators
ENABLE_MACRO_ANALYSIS=True  # ✅ Economic calendar, bonds, FX

# AI & Ensemble Models
ENABLE_ML_ENSEMBLE=True  # ✅ ARIMA + LSTM + XGBoost
ENABLE_SENTIMENT_ANALYSIS=True  # ✅ News sentiment
ENABLE_PROBABILITY_TREE=True  # ✅ Bull/Base/Bear scenarios
ENABLE_SESSION_ANALYSIS=True  # ✅ 15min session path projection

# Multi-Asset Context
ENABLE_BONDS_ANALYSIS=True  # ✅ 10Y, 2Y yields, TLT
ENABLE_FX_ANALYSIS=True  # ✅ USD Index, EUR/USD, JPY
ENABLE_ASIA_EUROPE_FUTURES=True  # ✅ Nikkei, DAX, FTSE
ENABLE_COMMODITIES=True  # ✅ Oil (CL), Gold (GC)
ENABLE_IWM_ANALYSIS=True  # ✅ Russell 2000 (small cap)
ENABLE_DIA_ANALYSIS=True  # ✅ Dow Jones (DIA)
ENABLE_SECTOR_ANALYSIS=True  # ✅ XLK (Tech), XLF (Finance), etc.

################################################################################
# 18. PATTERN DETECTION THRESHOLDS
################################################################################

# Reversal Patterns
REVERSAL_CONFIDENCE_THRESHOLD=0.75
BULLISH_REVERSAL_MIN_BARS=3
BEARISH_REVERSAL_MIN_BARS=3

# 缠论 Elliott Wave Thresholds
CHAN_MIN_WAVE_BARS=3
CHAN_IMPULSE_RATIO=1.618  # Fibonacci extension

# Volume-Price Patterns
VOLUME_SPIKE_ZSCORE=2.5
ACCUMULATION_MIN_BARS=5

# Wyckoff Patterns
WYCKOFF_MARKUP_THRESHOLD=0.02  # 2% move
WYCKOFF_MARKDOWN_THRESHOLD=0.02

# Gamma & Options Thresholds
GAMMA_FLIP_THRESHOLD=500000000  # $500M gamma
MAX_PAIN_DEVIATION_PERCENT=2
OPTIONS_FLOW_NOTIONAL_MIN=5000000  # $5M minimum

# Dealer Positioning
DEALER_DELTA_THRESHOLD=0.4  # 40% short/long

# Dark Pool
DARK_POOL_VOLUME_ANOMALY_ZSCORE=2.5
DARK_POOL_PARTICIPATION_MIN_PERCENT=30

# Short Squeeze
SHORT_SQUEEZE_PROBABILITY_THRESHOLD=0.65
SHORT_INTEREST_RATIO_THRESHOLD=3.0

# 0DTE Positioning
ZERO_DTE_NOTIONAL_ALERT=100000000  # $100M in 0DTE options

################################################################################
# 19. DATA RETENTION & HISTORY WINDOWS
################################################################################

# Data Retention Policies
DATA_RETENTION_DAYS=365  # 1 year of ticks/candles
CANDLE_HISTORY_MONTHS=24  # 2 years of complete history
NEWS_HISTORY_DAYS=90
OPTIONS_HISTORY_DAYS=30
DARK_POOL_HISTORY_DAYS=30

# Real-time vs Historical Cutoff
REALTIME_THRESHOLD_MINUTES=5  # Data older than 5min is historical
PRICE_CACHE_TTL_SECONDS=30
QUOTE_CACHE_TTL_SECONDS=5

################################################################################
# 20. OUTPUT & VISUALIZATION
################################################################################

# Analysis Output
GENERATE_CHARTS=True
CHART_OUTPUT_DIR=./output/charts
REPORT_OUTPUT_DIR=./output/reports
EXPORT_CSV=True
EXPORT_JSON=True
EXPORT_PARQUET=True

# Chart Specifications
CHART_DPI=300
CHART_STYLE=dark  # dark, light, seaborn
CHART_SIZE_WIDTH=1920
CHART_SIZE_HEIGHT=1080

# Report Formats
GENERATE_PDF_REPORT=True
GENERATE_HTML_DASHBOARD=True
GENERATE_MARKDOWN_SUMMARY=True

# 15-Minute Session Projection
PLOT_15MIN_SESSION_PATH=True
INCLUDE_PROBABILITY_BANDS=True
INCLUDE_SUPPORT_RESISTANCE=True

################################################################################
# 21. MARKET HOURS & TIMEZONE CONFIGURATION
################################################################################

# Market Hours (US Eastern)
MARKET_TIMEZONE=US/Eastern
PRE_MARKET_START=04:00
MARKET_OPEN=09:30
MARKET_CLOSE=16:00
POST_MARKET_END=20:00

# Extended Hours Trading
ENABLE_PREMARKET_ANALYSIS=True
ENABLE_POSTMARKET_ANALYSIS=True

# European Markets
EUROPE_MARKET_OPEN=02:00  # GMT+0
EUROPE_MARKET_CLOSE=16:30

# Asian Markets
ASIA_MARKET_OPEN_JST=09:00  # Nikkei open
ASIA_MARKET_OPEN_SGT=09:00  # Straits Times

################################################################################
# 22. PERFORMANCE TUNING
################################################################################

# Parallel Processing
PARALLEL_ANALYSIS_WORKERS=8
BATCH_PROCESS_SIZE=1000
ASYNC_ENABLED=True

# ML Model Optimization
ENABLE_GPU_ACCELERATION=True
QUANTIZATION_ENABLED=False  # Model compression
DISTILLATION_ENABLED=False  # Model distillation

# Caching Strategy
ENABLE_REDIS_CACHING=True
CACHE_WARM_ON_START=True
CACHE_TTL_PATTERNS=300
CACHE_TTL_NEWS=600

# Database Indexing
AUTO_INDEX_OPTIMIZATION=True
INDEX_MAINTENANCE_INTERVAL_HOURS=24

################################################################################
# 23. ALERT & ACTION TRIGGERS
################################################################################

# Signal Criteria
SIGNAL_LOOKBACK_BARS_SHORT=5
SIGNAL_LOOKBACK_BARS_MEDIUM=20
SIGNAL_LOOKBACK_BARS_LONG=50

# Alert Priority Levels
ALERT_CRITICAL_ENABLED=True  # Gamma flip, extreme moves
ALERT_HIGH_ENABLED=True  # Reversal patterns, large options flow
ALERT_MEDIUM_ENABLED=True  # Standard signals
ALERT_LOW_ENABLED=False  # Routine updates

# Rate Limiting (avoid alert fatigue)
MIN_ALERT_INTERVAL_SECONDS=60
MAX_ALERTS_PER_HOUR=100

################################################################################
# 24. SELF-CORRECTION & AUTO-LEARNING FRAMEWORK
################################################################################

# Data Quality Checks
RUN_DATA_QUALITY_CHECKS=True
REPAIR_MISSING_TICKS=True
INTERPOLATION_METHOD=linear  # linear, forward_fill, cubic
MAX_GAP_SIZE_BARS=5

# Model Performance Monitoring
TRACK_PREDICTION_ACCURACY=True
ACCURACY_CHECK_INTERVAL_TRADES=20
RETRAIN_THRESHOLD_ACCURACY=0.50  # Retrain if accuracy < 50%

# Drift Detection
DETECT_DISTRIBUTION_SHIFT=True
DRIFT_TEST=kolmogorov_smirnov
DRIFT_WINDOW_TRADES=100
AUTO_RETRAIN_ON_DRIFT=True

# Feature Importance Tracking
TRACK_FEATURE_IMPORTANCE=True
REMOVE_LOW_IMPORTANCE_FEATURES=True
IMPORTANCE_THRESHOLD=0.01

# Signal Validation Cascade
VALIDATE_SIGNAL_WITH_CHART_PATTERN=True
VALIDATE_SIGNAL_WITH_VOLUME=True
VALIDATE_SIGNAL_WITH_OPTIONS_FLOW=True
VALIDATE_SIGNAL_WITH_MACRO=True
VALIDATE_SIGNAL_WITH_SENTIMENT=True

# Ensemble Voting
ENSEMBLE_MODEL_COUNT=5
ENSEMBLE_VOTING_RULE=majority  # majority, weighted_average, consensus
CONSENSUS_THRESHOLD=0.7

# A/B Testing of Signals
ENABLE_AB_TESTING=True
TEST_WINDOW_TRADES=50
MIN_TEST_SAMPLE_SIZE=30

# Learning Loop
RECORD_ALL_TRADES=True
ANALYZE_WINNING_VS_LOSING_TRADES=True
UPDATE_STRATEGY_WEIGHTS=True
LEARNING_RATE=0.01

################################################################################
# END OF CONFIG FILE
# Questions? See: /docs/setup.md and /docs/strategy.md
