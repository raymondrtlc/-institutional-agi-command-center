################################################################################
# 9. DATABASE & TIME-SERIES STORAGE
################################################################################

# PostgreSQL - Primary database for ticks, candles, analysis results
# Used for: ✅ Storage of 5min-monthly candles, trade history
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_db_password_here
DB_NAME=agi_command_center
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=False

# TimescaleDB Extension - Hyper-efficient time-series compression
TIMESCALEDB_ENABLED=True

# ClickHouse - Ultra-fast OLAP for massive historical data
# Used for: ✅ Long-term tick/candle storage (100M+ records)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password_here
CLICKHOUSE_DATABASE=market_data

# MongoDB - Document storage for news/events
MONGODB_URI=mongodb://localhost:27017/trading_ai

################################################################################
# 10. REAL-TIME INFRASTRUCTURE & MESSAGE QUEUING
################################################################################

# Redis - In-memory cache for real-time quotes, signal queue
