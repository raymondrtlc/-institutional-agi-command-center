################################################################################
# 7. FREE DATABASE & STORAGE
################################################################################

# PostgreSQL - FREE open-source database
# Used for: ✅ Candle storage, analysis results
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_local_db_password
DB_NAME=agi_command_center
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# TimescaleDB - FREE open-source extension
TIMESCALEDB_ENABLED=True

# SQLite - FREE, lightweight alternative (single file)
# Used for: ✅ Local development, small deployments
SQLITE_DB_PATH=./data/agi_command_center.db

# ClickHouse - FREE open-source OLAP database
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=market_data

# MongoDB Community - FREE open-source
MONGODB_URI=mongodb://localhost:27017/trading_ai

# DuckDB - FREE in-process SQL database (ultra-lightweight)
DUCKDB_PATH=./data/market_data.duckdb

# Redis - FREE open-source in-memory database
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

################################################################################
# 8. FREE REAL-TIME INFRASTRUCTURE
################################################################################

# Kafka - FREE open-source message streaming
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_PRICE=market.price.es
KAFKA_TOPIC_NEWS=market.news.financial
KAFKA_GROUP_ID=agi-command-center

# RabbitMQ - FREE open-source message queue
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Apache NiFi - FREE data routing/transformation
NIFI_ENABLED=False
NIFI_HOST=localhost
NIFI_PORT=8080

################################################################################
# 9. FREE MACHINE LEARNING & AI
################################################################################

# HuggingFace - FREE transformers & models
# Get free API token: https://huggingface.co/
HUGGINGFACE_API_KEY=your_free_huggingface_token
HUGGINGFACE_MODEL_ID=finbert  # FREE FinBERT model

# OpenAI - FREE credits for new accounts ($5)
# Get free key: https://platform.openai.com/
# Limited: 3 requests/min on free tier
OPENAI_API_KEY=your_free_openai_key_here  # WARNING: Will deplete $5 quickly
OPENAI_MODEL=gpt-3.5-turbo  # Use cheaper models

# Anthropic Claude - NO FREE TIER (paid only)
# Skip this if budget-constrained
ANTHROPIC_API_KEY=  # Leave empty if no budget

# Ollama - FREE local LLM (run locally, no cloud)
# Get: https://ollama.ai/
OLLAMA_ENABLED=True
OLLAMA_MODEL=mistral  # FREE local model
OLLAMA_HOST=http://localhost:11434

# LLama2 - FREE open-source model (run locally)
LLAMA2_ENABLED=True
LLAMA2_MODEL_PATH=./models/llama-2-7b-chat.gguf

# Scikit-Learn - FREE machine learning library
SKLEARN_ENABLED=True

# XGBoost - FREE gradient boosting
XGBOOST_ENABLED=True

# PyTorch - FREE deep learning (CPU available)
PYTORCH_ENABLED=True
PYTORCH_DEVICE=cpu  # Use 'cuda' if GPU available

# TensorFlow - FREE deep learning
TENSORFLOW_ENABLED=True

# LightGBM - FREE gradient boosting
LIGHTGBM_ENABLED=True

# CatBoost - FREE gradient boosting
CATBOOST_ENABLED=True

# Optuna - FREE hyperparameter optimization
OPTUNA_ENABLED=True

# MLflow - FREE experiment tracking (local)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE=sqlite:///./mlflow.db

# Weights & Biases - FREE tier (limited)
WANDB_API_KEY=  # Leave empty - use local MLflow instead

################################################################################
# 10. FREE MONITORING & LOGGING
################################################################################

# Prometheus - FREE open-source metrics
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# Grafana - FREE open-source dashboards
GRAFANA_ENABLED=True
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ELK Stack (Elasticsearch, Logstash, Kibana) - FREE open-source
ELK_ENABLED=True
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Jaeger - FREE distributed tracing (open-source)
JAEGER_ENABLED=False
JAEGER_HOST=localhost
JAEGER_PORT=6831

# Sentry - FREE tier available
# Get free account: https://sentry.io/
SENTRY_DSN=your_free_sentry_dsn_here  # Optional

################################################################################
# 11. FREE CLOUD STORAGE (Limited)
################################################################################

# AWS S3 - FREE tier: 5GB storage (12 months)
# WARNING: Pay close attention to usage limits
AWS_ACCESS_KEY_ID=your_aws_key_here  # Optional - only if using S3
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=agi-command-center-data  # Use FREE tier carefully

# Google Cloud Storage - FREE tier: 5GB storage
# Get free account: https://cloud.google.com/
GCS_PROJECT_ID=your_gcs_project_id  # Optional
GCS_BUCKET=agi-command-center-gcs
GCS_CREDENTIALS_PATH=/path/to/gcs_credentials.json

# Azure Blob Storage - FREE tier: limited
AZURE_STORAGE_CONNECTION_STRING=  # Optional

# Local Storage - ALWAYS FREE
LOCAL_DATA_DIR=./data
LOCAL_CHARTS_DIR=./output/charts
LOCAL_BACKUP_DIR=./backup

