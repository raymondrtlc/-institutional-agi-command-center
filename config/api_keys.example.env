# API Keys Configuration
# Copy this file to api_keys.env and fill in your actual keys
# NEVER commit api_keys.env to version control!

# Polygon.io (Options & Futures Data)
POLYGON_API_KEY=your_polygon_api_key_here

# Alpha Vantage (Historical Data)
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Finnhub (News & Economic Data)
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI (News Aggregation)
NEWSAPI_API_KEY=your_newsapi_api_key_here

# Trading Economics (Economic Calendar)
TRADINGECONOMICS_API_KEY=your_tradingeconomics_api_key_here

# OpenAI (Optional - for advanced sentiment analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Slack Notifications (Optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Telegram Notifications (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=agi_command_center

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here

# Trading Account (Optional)
BROKER_API_KEY=your_broker_api_key_here
BROKER_SECRET_KEY=your_broker_secret_key_here
BROKER_ACCOUNT_ID=your_account_id_here

# Data Provider Alternatives (Optional)
# If using IQFeed or other data feeds
IQFEED_HOST=localhost
IQFEED_PORT=9009

# Cloud Storage (Optional)
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=True
LOG_LEVEL=INFO
