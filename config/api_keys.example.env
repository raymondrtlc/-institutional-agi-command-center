# ⚠️  SECURITY WARNING
# - NEVER commit api_keys.env to version control
# - Add api_keys.env to .gitignore
# - Use environment variables in production, not this file
# - Rotate keys periodically and monitor for unauthorized access

# ===== SETUP INSTRUCTIONS =====
# 1. Copy this file: cp config/api_keys.example.env config/api_keys.env
# 2. Fill in your actual API keys (see links below)
# 3. Ensure api_keys.env is in .gitignore
# 4. Load variables via: python -m dotenv load config/api_keys.env
# 5. Test connectivity: python scripts/test_api_connections.py

################################################################################
# 1. MARKET DATA PROVIDERS (REQUIRED FOR LIVE ES/SPY/FUTURES)
################################################################################

# Polygon.io - Real-time ES/SPY futures, options, stocks data
# Get key: https://polygon.io/docs/getting-started
# Used for: ✅ Live ES futures analysis, multi-timeframe candles (5min-monthly)
POLYGON_API_KEY=your_polygon_api_key_here

# Alpha Vantage - Historical OHLCV data, technical indicators
# Get key: https://www.alphavantage.co/
# Used for: ✅ Historical analysis, 缠论 wave patterns
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Finnhub - Real-time news, earnings calendar, economic indicators
# Get key: https://finnhub.io/
# Used for: ✅ Earnings impact, breaking news, economic calendar
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI - Aggregated news from 1000+ sources (Reuters, WSJ, CNBC, CNN)
# Get key: https://newsapi.org/
# Used for: ✅ Real-time breaking news summary, media monitoring
NEWSAPI_API_KEY=your_newsapi_api_key_here

# Trading Economics - Economic calendar, macro indicators
# Get key: https://tradingeconomics.com/
