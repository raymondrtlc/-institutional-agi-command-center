# ⚠️  SECURITY WARNING
# - NEVER commit api_keys.env to version control
# - Add api_keys.env to .gitignore
# - Use environment variables in production, not this file
# - Rotate keys periodically and monitor for unauthorized access

# ===== SETUP INSTRUCTIONS =====
# 1. Copy this file: cp config/api_keys.example.env config/api_keys.env
# 2. Fill in your actual API keys (see links below)
# 3. Ensure api_keys.env is in .gitignore
# 4. Load variables via: python -m dotenv load config/api_keys.env
# 5. Test connectivity: python scripts/test_api_connections.py

################################################################################
# 1. FREE MARKET DATA PROVIDERS (NO PAYMENT REQUIRED)
################################################################################

# Yahoo Finance - FREE real-time market data (no key needed)
# Used for: ✅ Live ES/SPY/QQQ data, options data, historical candles
YAHOO_FINANCE_API_KEY=  # Leave empty - FREE with yfinance library

# AlphaVantage FREE tier - 5 calls/min (500 calls/day)
# Get free key: https://www.alphavantage.co/
# Used for: ✅ Historical OHLCV, technical indicators
ALPHAVANTAGE_API_KEY=your_free_alphavantage_key_here

# Polygon.io FREE tier - 5 API calls/minute
# Get free key: https://polygon.io/
# Used for: ✅ Options data, derivatives, multi-timeframe candles
POLYGON_API_KEY=your_free_polygon_key_here

# Finnhub FREE tier - 60 API calls/minute
# Get free key: https://finnhub.io/
# Used for: ✅ Real-time news, earnings calendar, market data
FINNHUB_API_KEY=your_free_finnhub_key_here

# NewsAPI FREE tier - 500 requests/day
# Get free key: https://newsapi.org/
# Used for: ✅ Real-time breaking news from 1000+ sources
NEWSAPI_API_KEY=your_free_newsapi_key_here

# IEX Cloud FREE tier - 100 messages/month
# Get free key: https://iexcloud.io/
# Used for: ✅ Alternative market data, earnings tracking
IEX_CLOUD_API_KEY=your_free_iex_cloud_key_here

# CoinGecko FREE API - Unlimited (no key needed)
# Used for: ✅ Crypto correlation analysis (BTC, ETH for macro sentiment)
COINGECKO_API_KEY=  # Leave empty - FREE, no key required

# FRED (Federal Reserve) - FREE API
# Get free key: https://fred.stlouisfed.org/docs/api/
# Used for: ✅ Economic data, bond yields, VIX, credit spreads
FRED_API_KEY=your_free_fred_key_here

# Trading Economics FREE tier
# Get free key: https://tradingeconomics.com/
# Used for: ✅ Economic calendar events
TRADINGECONOMICS_API_KEY=your_free_tradingeconomics_key_here

# Alpha Vantage NEWS - FREE
# Used for: ✅ News aggregation
ALPHAVANTAGE_NEWS_API_KEY=your_free_alphavantage_key_here

# World Bank API - FREE (no key needed)
# Used for: ✅ Global macro data
WORLD_BANK_API_KEY=  # Leave empty - FREE

# Twelve Data FREE tier - 800 API calls/day
# Get free key: https://twelvedata.com/
# Used for: ✅ Futures data (ES, NQ, YM, CL, GC)
TWELVE_DATA_API_KEY=your_free_twelve_data_key_here

# Binance FREE API - Unlimited
# No key needed for public data
