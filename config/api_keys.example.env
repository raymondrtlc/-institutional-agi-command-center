################################################################################
# 15. SYSTEM CONFIGURATION
################################################################################

# Environment Type
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Market Hours
MARKET_TIMEZONE=US/Eastern
PRE_MARKET_START=04:00
MARKET_OPEN=09:30
MARKET_CLOSE=16:00
POST_MARKET_END=20:00

# Performance Tuning
PARALLEL_ANALYSIS_WORKERS=4  # Reduce for local machine
BATCH_PROCESS_SIZE=100  # Smaller batches
ASYNC_ENABLED=True

# Cache Settings
ENABLE_REDIS_CACHING=True
CACHE_TTL_SECONDS=300

################################################################################
# 16. DATA QUALITY & SELF-CORRECTION (ALL FREE)
################################################################################

# Data Validation
VALIDATE_DATA_QUALITY=True
AUTO_REPAIR_GAPS=True

# Model Validation
CROSS_VALIDATE_PREDICTIONS=True
AUTO_RETRAIN_ON_DRIFT=True

# Trade Signal Validation
REQUIRE_MULTI_TIMEFRAME_CONFIRMATION=True

# Learning Loop
RECORD_ALL_TRADES=True
ENABLE_AB_TESTING=True
UPDATE_STRATEGY_WEIGHTS=True

################################################################################
# COST SUMMARY
################################################################################
# Total Cost: $0-5/month (if using free tiers properly)
# - Most data APIs: FREE tier available
# - Databases: FREE open-source
# - ML/AI: FREE libraries (local) or tiny HuggingFace credits
# - Cloud Storage: Use local storage to avoid S3/GCS charges
# - Infrastructure: All FREE open-source
#
# COST WARNINGS:
# ⚠️  OpenAI: $5 free credits burn FAST - use Ollama local instead
# ⚠️  AWS S3: Monitor usage - can exceed FREE tier quickly
# ⚠️  Datadog: Premium only - use Prometheus/Grafana instead
# ⚠️  Reuters/Bloomberg: Paid only - use NewsAPI instead
#
# RECOMMENDED SETUP:
# 1. Use Yahoo Finance for price data (FREE)
# 2. Use FRED for macro data (FREE)
# 3. Use HuggingFace FinBERT locally (FREE)
# 4. Use Ollama for LLM analysis (FREE, no API calls)
# 5. Use local PostgreSQL + TimescaleDB (FREE)
# 6. Use Prometheus + Grafana for monitoring (FREE)
#
################################################################################
# END OF CONFIG FILE
